# =============================================================================
# Nexus Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# AI Configuration
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# Optional: For embeddings (if using OpenAI instead of local)
OPENAI_API_KEY=sk-your-openai-key-here

# Database (SQLite by default - zero setup!)
DATABASE_URL=sqlite+aiosqlite:///./data/nexus.db
DATABASE_URL_SYNC=sqlite:///./data/nexus.db

# Optional: Use PostgreSQL/Supabase instead
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
# DATABASE_URL_SYNC=postgresql://user:pass@host:5432/db

# Optional: Supabase Configuration (only needed if using Supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Redis (optional - for caching and sessions)
REDIS_URL=redis://localhost:6379

# Vector Database
CHROMADB_PATH=./data/chroma

# Obsidian Integration
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Claude History Sync
CLAUDE_HISTORY_PATH=~/.claude/projects

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Voice / ElevenLabs Configuration
# Get API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# Voice ID (default: Adam - pNInz6obpgDQGcFmaJgB)
# Find voice IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Google Calendar Integration
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API at: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# Plaid Integration (for banking/investment data)
# Sign up at: https://dashboard.plaid.com/signup
# Get credentials from: https://dashboard.plaid.com/developers/keys
# Sandbox is free and provides test data for development
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
# Environment: sandbox (free testing), development (real data, limited), production
PLAID_ENV=sandbox

# GitHub Integration
# Personal Access Token for GitHub API
# Create one at: https://github.com/settings/tokens
# Required scopes: repo (for private repos), read:user
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
